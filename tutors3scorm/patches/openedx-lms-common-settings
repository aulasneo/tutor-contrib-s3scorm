    from storages.backends.s3boto3 import S3Boto3Storage

    return S3Boto3Storage(custom_domain=settings.LMS_BASE)

XBLOCK_SETTINGS.setdefault("ScormXBlock", {})["STORAGE_FUNC"] = scorm_storage

